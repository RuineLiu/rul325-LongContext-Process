data/faiss_index/

# =============================================================================
# Virtual environments
# =============================================================================
venv/
.venv/
env/

# =============================================================================
# Python cache
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# =============================================================================
# Jupyter — generated HTML exports, checkpoints, and auto-executed copies
# =============================================================================
notebooks/*.html
notebooks/analysis_run.ipynb
notebooks/extra_analysis_results.ipynb
.ipynb_checkpoints/
**/.ipynb_checkpoints/

