# macOS / IDE
# =============================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# =============================================================================
# NOTE: the following ARE committed intentionally
#   data/processed/          — curated datasets needed to reproduce experiments
#   results/*.json            — experiment outputs (shows results without re-running)
#   results/figures/          — paper figures
#   .env.example              — template showing required env vars (no real keys)
# =============================================================================
